# Deployer private key (no 0x prefix needed for some tools, but include it for clarity)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia RPC — get one free from Infura or Alchemy
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Etherscan API key — for contract verification (optional but recommended)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# After deployment, fill these in for the frontend
NEXT_PUBLIC_CYCLE_TOKEN_ADDRESS=
NEXT_PUBLIC_CYCLE_STAKING_ADDRESS=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
